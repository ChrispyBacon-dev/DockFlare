# dockflare-next-ui/Dockerfile
# Stage 1: Install dependencies and build the Next.js application
FROM node:18-alpine AS builder # <<< THIS LINE WAS MISSING/INCOMPLETE
LABEL stage=nextjs-builder

WORKDIR /app

# Copy package.json and lock file(s)
COPY package.json yarn.lock* package-lock.json* pnpm-lock.yaml* ./

# Install dependencies
RUN npm install --legacy-peer-deps

# Copy the rest of the application code
COPY . .

# Build the Next.js application
# Ensure next.config.ts has output: 'standalone'
RUN npm run build

# Stage 2: Create the final production image for the standalone Next.js server
FROM node:18-alpine AS runner
LABEL stage=nextjs-runner # This label is optional, but good for clarity

WORKDIR /app

ENV NODE_ENV production
# ENV PORT 3000 Already set in compose, EXPOSE is enough here

# Copy the standalone application from the 'builder' stage
COPY --from=builder /app/.next/standalone ./

# Copy the public assets
COPY --from=builder /app/public ./public

# Copy the static assets generated by Next.js build
COPY --from=builder /app/.next/static ./.next/static


# Expose the port the Next.js standalone server will run on
EXPOSE 3000

# Command to start the Next.js standalone server
CMD ["node", "server.js"]